def work_calor(work_desc):
    """
    inputs an exercise description and user input time,
    returns the calories burned in the workout
    """
    with open('METvalues.json', 'r') as file:
        metvalues = json.load(file)
    #gets time of exercise
    while True:
        time = input("How long did you exercise for in minutes? ")
        if time.isdigit():
            break
        else:
            print("please input an integer number of minutes")
    #gets MET value
    for diction in metvalues:
        if work_desc.lower() == diction["Description"].lower():
            met = float(diction["MET"])

    #calculates calories from MET, bodyweight, and time
    calories = met*int(time)*bodyweight/60


    return(calories)

def add_workout(calories):
    """
    Input is a workouts calories,
    subtracts the calories of the workout from daily macros
    """
    global Daily_Macros
    Daily_Macros["energy"] += -calories

    return()

def end_day(bas_met_rat):
    global day
    global Daily_Macros
    global bodyweight
    add_workout(bas_met_rat)

    with open('daily_data.json', 'r') as file:
        dailydata = json.load(file)
    #defines useful daily data as a dictionary
    today = {
        "day":f"day{day}",
        "macros":Daily_Macros,
        "weight":bodyweight
    }
    #updates dailydata jason file with the day
    dailydata.append(today)

    with open('daily_data.json', 'w') as f:
        json.dump(dailydata,f,indent = 1)

    #moves on to the next day
    day += 1
    bodyweight = 0

    return()


