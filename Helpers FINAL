def asign_macros(food_desc):
    """
    function that inputs a description of a food
    then gets all nutrient information
    and returns macros per 100 grams as a dictionary
    """
    global macro_values
    result = {}

    with open('Fooddata.json', 'r') as file:
            fooddata = json.load(file)
    foods = fooddata["FoundationFoods"]
    #withdraw all macros and store in a dictionary
    for food in foods:
        if food["description"] == food_desc:

            for nutrient in food["foodNutrients"]:
                name = nutrient["nutrient"]["name"]
                amount = nutrient.get("amount", 0)
                unit = nutrient["nutrient"]["unitName"]

                if name == "Protein":
                    result["protein"] = amount
                elif name == "Total lipid (fat)":
                    result["fat"] = amount
                elif name == "Carbohydrate, by difference":
                    result["carbs"] = amount
                elif name == "Fiber, total dietary":
                    result["fiber"] = amount
                elif name == "Sodium, Na":
                    result["sodium"] = amount
                elif name == "Energy" and unit == "kcal":
                    result["energy"] = amount

    #give value of 0 to undefined macros
    if len(result) < 6:
        for item in macro_values:
            try:
                result[item]
            except KeyError:
                result[item] = 0


    return(result)


def start_day():
    """function that builds a global dictionary of daily values and or resets to 0
    also gets a users start of day weight
    """
    global Daily_Macros
    global macro_values
    global bodyweight
    global day

    print("Starting a new day")

    #get users start of day weight
    weight_units = ["pounds","kilograms"]
    while True:
        weight_unit = input("What unit are you going to input your weight as, Pounds or Kilograms? ")
        if weight_unit.lower() in weight_units:
            break
        else:
            print("Please enter either pounds or kilograms")
    while True:
        weight = input("Please enter your weight to the nearest integer: ")
        if weight.isdigit():
            weight = int(weight)
            break
        else:
            print("Please enter an integer ")
    if weight_unit == "pounds":
        bodyweight = weight/2.205
    else:
        bodyweight = weight


    Daily_Macros.clear
    for items in macro_values:
        Daily_Macros[items] = 0


    return()

def add_item(food_desc,quant):
    """function that adds up input macros to a global variable containing dailyn macros
    input is which food description you are inputting and how much of that item(amount of 100 grams)
    that you are eating
    """
    global Daily_Macros
    global macro_values
    macros = asign_macros(food_desc)
    for item in macro_values:
        Daily_Macros[item] += quant*macros[item]

    return()

def find_work():
